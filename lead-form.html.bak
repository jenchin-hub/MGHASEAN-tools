<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>漢方南向策略健檢申請｜MGHBIO 大鬍子藥師</title>
<style>
  /* ── 填入你的 Google Form 設定 ─────────────────────────────
     步驟：到 forms.google.com 建表單後，預覽表單，
     從網址取得 FORM_ID，再從原始碼找各欄位 entry.XXXXXXX
  ────────────────────────────────────────────────────────── */

  :root {
    --teal:       #0F6E56;
    --teal-mid:   #1D9E75;
    --teal-light: #E1F5EE;
    --teal-border:#9FE1CB;
    --amber:      #BA7517;
    --amber-light:#FAEEDA;
    --text:       #1a1a1a;
    --text-muted: #6b7280;
    --border:     #e5e7eb;
    --bg:         #ffffff;
    --bg-soft:    #f9fafb;
    --radius:     10px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg-soft);
    color: var(--text);
    min-height: 100vh;
    padding: 2rem 1rem;
  }
  .card {
    max-width: 560px;
    margin: 0 auto;
    background: var(--bg);
    border-radius: 16px;
    box-shadow: 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.06);
    overflow: hidden;
  }
  .card-header {
    background: var(--teal);
    padding: 1.5rem 1.5rem 1.25rem;
    color: #fff;
  }
  .card-header .badge {
    display: inline-block;
    background: rgba(255,255,255,.2);
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 10px;
    letter-spacing: .04em;
  }
  .card-header h1 { font-size: 20px; font-weight: 600; margin-bottom: 4px; }
  .card-header p  { font-size: 13px; opacity: .85; }
  .card-body { padding: 1.5rem; }

  .field { margin-bottom: 1.1rem; }
  label  { display: block; font-size: 13px; font-weight: 500; color: var(--text-muted); margin-bottom: 5px; }
  label .req { color: #e24b4a; margin-left: 2px; }
  input[type=text], input[type=email], input[type=tel] {
    width: 100%; padding: 9px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 14px; color: var(--text);
    background: var(--bg);
    transition: border-color .15s;
  }
  input:focus { outline: none; border-color: var(--teal); }
  .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media(max-width:420px){ .row2 { grid-template-columns: 1fr; } }

  .chips { display: flex; flex-wrap: wrap; gap: 7px; }
  .chip {
    padding: 7px 14px;
    border: 1px solid var(--border);
    border-radius: 20px;
    font-size: 13px;
    cursor: pointer;
    color: var(--text-muted);
    background: var(--bg);
    transition: all .15s;
    user-select: none;
  }
  .chip:hover { border-color: var(--teal); color: var(--teal); }
  .chip.sel  { background: var(--teal-light); border-color: var(--teal); color: var(--teal); font-weight: 500; }

  .divider { border: none; border-top: 1px solid var(--border); margin: 1.25rem 0; }

  .btn-submit {
    width: 100%; padding: 13px;
    background: var(--teal);
    color: #fff; border: none;
    border-radius: var(--radius);
    font-size: 15px; font-weight: 600;
    cursor: pointer;
    transition: background .15s;
  }
  .btn-submit:hover { background: var(--teal-mid); }
  .btn-submit:disabled { opacity: .6; cursor: not-allowed; }
  .note { font-size: 12px; color: var(--text-muted); text-align: center; margin-top: 10px; }

  /* success */
  #successView { display: none; padding: 2.5rem 1.5rem; text-align: center; }
  .check-circle {
    width: 60px; height: 60px; border-radius: 50%;
    background: var(--teal-light);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1rem;
    font-size: 28px; color: var(--teal);
  }
  #successView h2 { font-size: 20px; font-weight: 600; margin-bottom: 6px; }
  #successView p  { font-size: 14px; color: var(--text-muted); line-height: 1.6; }
  .success-box {
    margin-top: 1.5rem; padding: 1rem 1.25rem;
    background: var(--teal-light);
    border-radius: var(--radius);
    font-size: 13px; color: var(--teal); font-weight: 500; line-height: 1.5;
  }

  /* error */
  .err-msg { display: none; color: #e24b4a; font-size: 13px; margin-top: 8px; }
</style>
</head>
<body>

<div class="card">
  <div class="card-header">
    <span class="badge">限量 10 家｜演講專屬</span>
    <h1>漢方南向策略健檢 申請表</h1>
    <p>填寫約 90 秒｜我們將在 24 小時內與您聯繫</p>
  </div>

  <div class="card-body">
    <div id="formView">

      <div class="row2">
        <div class="field">
          <label>公司名稱 <span class="req">*</span></label>
          <input type="text" id="f-company" placeholder="例：台灣本草生技">
        </div>
        <div class="field">
          <label>您的職稱 <span class="req">*</span></label>
          <input type="text" id="f-title" placeholder="例：總經理">
        </div>
      </div>

      <div class="row2">
        <div class="field">
          <label>聯絡電話 <span class="req">*</span></label>
          <input type="tel" id="f-phone" placeholder="09XX-XXX-XXX">
        </div>
        <div class="field">
          <label>電子郵件</label>
          <input type="email" id="f-email" placeholder="your@company.com">
        </div>
      </div>

      <hr class="divider">

      <div class="field">
        <label>最想優先進入哪個市場？<span class="req">*</span>（可多選）</label>
        <div class="chips" id="chips-market">
          <span class="chip" data-v="馬來西亞">🇲🇾 馬來西亞</span>
          <span class="chip" data-v="新加坡">🇸🇬 新加坡</span>
          <span class="chip" data-v="泰國">🇹🇭 泰國</span>
          <span class="chip" data-v="越南">🇻🇳 越南</span>
          <span class="chip" data-v="印尼">🇮🇩 印尼</span>
          <span class="chip" data-v="還不確定">還不確定</span>
        </div>
      </div>

      <div class="field" style="margin-top:1.1rem">
        <label>目前最大的困難是？<span class="req">*</span>（選最痛的一項）</label>
        <div class="chips" id="chips-pain">
          <span class="chip" data-v="不知道哪個產品適合出海">不知道哪個產品適合出海</span>
          <span class="chip" data-v="法規文件不知道怎麼準備">法規文件不知道怎麼準備</span>
          <span class="chip" data-v="Halal認證不了解">Halal 認證不了解</span>
          <span class="chip" data-v="找不到當地通路夥伴">找不到當地通路夥伴</span>
          <span class="chip" data-v="沒有資源做市場調查">沒有資源做市場調查</span>
        </div>
      </div>

      <hr class="divider">

      <p class="err-msg" id="errMsg">請填寫所有必填項目（標 * 的欄位）</p>

      <button class="btn-submit" id="submitBtn" onclick="submitForm()">
        申請南向策略健檢 →
      </button>
      <p class="note">您的資料僅用於本次顧問配對，不做其他用途</p>
    </div>

    <div id="successView">
      <div class="check-circle">✓</div>
      <h2>申請已收到！</h2>
      <p>我們將在 <strong>24 小時內</strong>以電話或 Email 與您聯繫。<br>請留意明天的來電。</p>
      <div class="success-box">
        您的專屬 Checklist PDF 也會在 Email 中一併寄送。<br>
        在等待期間，可以先到<a href="checklist.html" style="color:var(--teal);font-weight:600"> 自評 Checklist </a>做個初步評估。
      </div>
    </div>
  </div>
</div>

<script>
// ══════════════════════════════════════════════════════════
//  填入你的 Google Forms 設定
//  取得方式：預覽表單 → 網址取 FORM_ID → 原始碼找 entry.XXXX
// ══════════════════════════════════════════════════════════
var FORM_ID    = 'YOUR_GOOGLE_FORM_ID';   // ← 換成你的 Form ID
var ENTRY = {
  company : 'entry.XXXXXXXXX',           // ← 公司名稱的 entry ID
  title   : 'entry.XXXXXXXXX',           // ← 職稱
  phone   : 'entry.XXXXXXXXX',           // ← 電話
  email   : 'entry.XXXXXXXXX',           // ← Email
  market  : 'entry.XXXXXXXXX',           // ← 市場（核取方塊，多值同一 entry）
  pain    : 'entry.XXXXXXXXX'            // ← 困難（單選）
};
// ══════════════════════════════════════════════════════════

document.querySelectorAll('#chips-market .chip').forEach(function(c){
  c.onclick = function(){ c.classList.toggle('sel'); };
});
document.querySelectorAll('#chips-pain .chip').forEach(function(c){
  c.onclick = function(){
    document.querySelectorAll('#chips-pain .chip').forEach(function(x){ x.classList.remove('sel'); });
    c.classList.add('sel');
  };
});

function submitForm(){
  var company = document.getElementById('f-company').value.trim();
  var title   = document.getElementById('f-title').value.trim();
  var phone   = document.getElementById('f-phone').value.trim();
  var email   = document.getElementById('f-email').value.trim();
  var markets = Array.from(document.querySelectorAll('#chips-market .sel')).map(function(c){ return c.dataset.v; });
  var pains   = Array.from(document.querySelectorAll('#chips-pain .sel')).map(function(c){ return c.dataset.v; });
  var err     = document.getElementById('errMsg');

  if(!company || !title || !phone || !markets.length || !pains.length){
    err.style.display = 'block';
    return;
  }
  err.style.display = 'none';

  var btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = '送出中…';

  // 組成 Google Forms 送出 URL（no-cors iframe trick）
  var base = 'https://docs.google.com/forms/d/e/' + FORM_ID + '/formResponse?';
  var params = [
    ENTRY.company + '=' + encodeURIComponent(company),
    ENTRY.title   + '=' + encodeURIComponent(title),
    ENTRY.phone   + '=' + encodeURIComponent(phone),
    ENTRY.email   + '=' + encodeURIComponent(email),
    ENTRY.pain    + '=' + encodeURIComponent(pains[0])
  ];
  markets.forEach(function(m){
    params.push(ENTRY.market + '=' + encodeURIComponent(m));
  });

  // 用隱藏 iframe 送出（避免跨域問題）
  var iframe = document.createElement('iframe');
  iframe.style.display = 'none';
  iframe.name = 'hidden_iframe';
  document.body.appendChild(iframe);

  var form = document.createElement('form');
  form.method = 'POST';
  form.action = 'https://docs.google.com/forms/d/e/' + FORM_ID + '/formResponse';
  form.target = 'hidden_iframe';

  var allFields = {};
  allFields[ENTRY.company] = company;
  allFields[ENTRY.title]   = title;
  allFields[ENTRY.phone]   = phone;
  allFields[ENTRY.email]   = email;
  allFields[ENTRY.pain]    = pains[0];

  Object.keys(allFields).forEach(function(k){
    var inp = document.createElement('input');
    inp.type = 'hidden'; inp.name = k; inp.value = allFields[k];
    form.appendChild(inp);
  });
  markets.forEach(function(m){
    var inp = document.createElement('input');
    inp.type = 'hidden'; inp.name = ENTRY.market; inp.value = m;
    form.appendChild(inp);
  });

  document.body.appendChild(form);
  form.submit();

  setTimeout(function(){
    document.getElementById('formView').style.display = 'none';
    document.getElementById('successView').style.display = 'block';
  }, 800);
}
</script>
</body>
</html>
